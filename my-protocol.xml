<?xml version="1.0" encoding="UTF-8"?>
<protocol name="myprotocol">
  <interface name="my_workspace_manager" version="1">
    
    <request name="set_workspace">
      <description summary="switch to a specific workspace index"/>
      <arg name="index" type="uint" summary="the workspace number (0-9)"/>
    </request>

    <event name="workspace_activated">
      <description summary="sent when the active workspace changes"/>
      <arg name="index" type="uint" summary="the new active workspace index"/>
    </event>

    <request name="release" type="destructor">
      <description summary="destroy the manager object"/>
    </request>
    
  </interface>
</protocol>
